<div class="flex flex-col mt-10">
  <h2 class="font-bold text-2xl text-left">LINE</h2>
  <% if current_user&.linked_with?(:line) %>
    <div class="text-left">
      <p>連携済みです</p>
    </div>
  <% else %>
    <div class="text-left">
      <p>リンクか QR コードで友だち追加をしてね</p>

      <div class="mt-4">
        <a href='https://lin.ee/zvges59'
           class="px-4 py-2 rounded-lg bg-red-200 text-amber-800 hover:border-slate-200 hover:bg-red-300 hover:shadow transition duration-150" %>
          友だちに追加
        </a>
      </div>
      <div class="text-center mt-4">
        <img src="images/Habita_line.png" alt="共だち追加QRコード" width="200">
      </div>
    </div>
  <% end %>
</div>
